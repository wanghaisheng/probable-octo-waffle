# =============================================================================
# NEXT.JS WEB APP ENVIRONMENT VARIABLES
# =============================================================================
# These variables are specific to the Next.js web application
# Commit this example .env file to the repository as a template; do not commit real .env with secrets
# 🔐 AUTHENTICATION (Clerk)
# For contributors: copy this file to .env and populate real secrets locally or via CI
# Test/Development Environment (currently active)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhook signing secret (from Clerk Dashboard > Webhooks)
# Used to verify webhook signatures — set this after creating the webhook endpoint
CLERK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# 🌐 APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Public URL for the web application
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Token used to read uninstall feedback from /api/extension-feedback (GET)
# Send it in the x-feedback-token header.
EXTENSION_FEEDBACK_READ_TOKEN=

# -----------------------------------------------------------------------------
# UPSTASH REDIS (Vercel KV)
# -----------------------------------------------------------------------------
# Provided automatically by Vercel KV integration, or set manually for local dev
KV_REST_API_URL=
KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# 📧 NEWSLETTER SERVICES
# -----------------------------------------------------------------------------
# Choose ONE newsletter provider by uncommenting and filling in the appropriate section:

# Option 1: MailerLite
# MAILERLITE_API_KEY=your_mailerlite_api_key_here
# MAILERLITE_GROUP_IDS=group_id_1,group_id_2  # Optional: default groups for all subscribers

# Option 2: ConvertKit (Kit)
# CONVERTKIT_API_KEY=your_convertkit_api_key_here
# CONVERTKIT_FORM_ID=your_form_id_here
# CONVERTKIT_TAG_IDS=123,456  # Optional: default tag IDs for all subscribers

# Option 3: Substack (iframe-only, no API)
# SUBSTACK_PUBLICATION_URL=https://yourpublication.substack.com
# SUBSTACK_EMBED_URL=https://yourpublication.substack.com/embed  # Optional: custom embed URL

# -----------------------------------------------------------------------------
# 📊 OPENPANEL ANALYTICS
# -----------------------------------------------------------------------------
# Client ID from OpenPanel dashboard (https://openpanel.dev)
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
# Client Secret for server-side event tracking (keep secret, do NOT prefix with NEXT_PUBLIC_)
OPENPANEL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 🔄 INHERITED FROM ROOT .env.local
# -----------------------------------------------------------------------------
# The following variables are inherited from the root .env.local:
# - GITHUB_TOKEN
# - GITHUB_CLIENT_ID
# - GITHUB_CLIENT_SECRET
# - NEXT_PUBLIC_SENTRY_DSN
# - SENTRY_AUTH_TOKEN
# - SENTRY_ORG
# - SENTRY_PROJECT
# - FLAGS_SECRET
# - RSS_FEED_URL
