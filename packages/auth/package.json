{
  "name": "@thedaviddias/auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./middleware": {
      "types": "./src/server/middleware.ts",
      "default": "./src/server/middleware.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./types": {
      "types": "./src/core/types.ts",
      "default": "./src/core/types.ts"
    },
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "catalog:"
  },
  "devDependencies": {
    "@thedaviddias/config-typescript": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  }
}
